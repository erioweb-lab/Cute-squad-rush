{
  "entities": {
    "UserProgress": {
      "title": "User Progress",
      "description": "Stores player's coins, high score, and permanent upgrades.",
      "type": "object",
      "properties": {
        "coins": {
          "type": "integer",
          "description": "Current number of coins the player has."
        },
        "highScore": {
          "type": "integer",
          "description": "The highest score achieved by the player."
        },
        "upgrades": {
          "type": "object",
          "properties": {
            "attackPower": { "type": "integer" },
            "fireRate": { "type": "integer" },
            "bulletSize": { "type": "integer" }
          },
          "required": ["attackPower", "fireRate", "bulletSize"]
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the progress was saved."
        },
        "stats": {
          "type": "object",
          "properties": {
            "totalKills": { "type": "integer" },
            "totalCoins": { "type": "integer" },
            "totalScore": { "type": "integer" },
            "maxStage": { "type": "integer" },
            "claimedAchievements": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["totalKills", "totalCoins", "totalScore", "maxStage", "claimedAchievements"]
        }
      },
      "required": ["coins", "highScore", "upgrades", "stats", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProgress",
      "description": "User progress document indexed by UID."
    }
  }
}
