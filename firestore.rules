rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - coins: int (required) - Current coins
    //   - highScore: int (required) - Best score
    //   - upgrades: map (required) - Permanent upgrades
    //     - attackPower: int
    //     - fireRate: int
    //     - bulletSize: int
    //   - updatedAt: timestamp (required) - Last sync time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
       return request.auth != null;
    }
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validator
    function isValidUserProgress(data) {
      return hasOnlyAllowedFields(['coins', 'highScore', 'upgrades', 'stats', 'updatedAt']) &&
             data.coins is int && data.coins >= 0 &&
             data.highScore is int && data.highScore >= 0 &&
             data.upgrades is map &&
             data.stats is map &&
             data.stats.keys().hasOnly(['totalKills', 'totalCoins', 'totalScore', 'maxStage', 'claimedAchievements']) &&
             data.stats.totalKills is int && data.stats.totalKills >= 0 &&
             data.stats.totalCoins is int && data.stats.totalCoins >= 0 &&
             data.stats.totalScore is int && data.stats.totalScore >= 0 &&
             data.stats.maxStage is int && data.stats.maxStage >= 0 &&
             data.stats.claimedAchievements is list &&
             data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProgress(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProgress(request.resource.data);
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
